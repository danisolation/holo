# Database (Aiven PostgreSQL)
# Replace postgresql:// with postgresql+asyncpg:// and append ?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname?ssl=require

# Crawling Configuration
VNSTOCK_SOURCE=VCI
CRAWL_BATCH_SIZE=50
CRAWL_DELAY_SECONDS=2.0
CRAWL_MAX_RETRIES=3
BACKFILL_START_DATE=2023-07-01

# Scheduler
DAILY_CRAWL_HOUR=15
DAILY_CRAWL_MINUTE=30
TIMEZONE=Asia/Ho_Chi_Minh
